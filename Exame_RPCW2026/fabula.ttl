#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/rpcw2026/fabula#Adulacao_Raposa
:Adulacao_Raposa rdf:type owl:NamedIndividual ,
                          :Adulacao ;
                 rdfs:comment "\"Estratégia usada pela Raposa para elogiar falsamente o Corvo\"" .


###  http://www.semanticweb.org/rpcw2026/fabula#Arvore_Alta
:Arvore_Alta rdf:type owl:NamedIndividual ,
                      :Arvore ;
             :localizadoEm :Arvore_Alta ;
             owl:topDataProperty """nome = \"Árvore alta\"
descricao = \"Árvore onde o Corvo estava empoleirado\"""" .


###  http://www.semanticweb.org/rpcw2026/fabula#Astucia_Raposa
:Astucia_Raposa rdf:type owl:NamedIndividual ,
                         :Astucia ;
                owl:topDataProperty """nome = \"Mestre Raposa\"
descricao = \"Raposa astuta que enganou o Corvo através de elogios\"""" ;
                rdfs:comment "\"Característica usada pela Raposa para enganar o Corvo\"" .


###  http://www.semanticweb.org/rpcw2026/fabula#Base_Arvore
:Base_Arvore rdf:type owl:NamedIndividual ,
                      :Local ;
             owl:topDataProperty """nome = \"Base da árvore\"
descricao = \"Local onde a Raposa se aproximou\"""" .


###  http://www.semanticweb.org/rpcw2026/fabula#Bosque
:Bosque rdf:type owl:NamedIndividual ,
                 :Bosque ;
        :viveEm :Bosque ;
        owl:topDataProperty """nome = \"Bosque\"
descricao = \"Local onde decorre a fábula\"""" .


###  http://www.semanticweb.org/rpcw2026/fabula#Confusao_Corvo
:Confusao_Corvo rdf:type owl:NamedIndividual ,
                         :Confusao ;
                :temSentimento :Confusao_Corvo ;
                rdfs:comment "\"Estado emocional do Corvo após perder o queijo\"" .


###  http://www.semanticweb.org/rpcw2026/fabula#Corvo_Mestre
:Corvo_Mestre rdf:type owl:NamedIndividual ,
                       :Corvo ;
              :possui :Queijo_Valioso ;
              owl:topDataProperty """nome = \"Mestre Corvo\"
descricao = \"Corvo vaidoso que segurava um queijo no bico\"
estadoInicial = \"Tinha o queijo no bico e estava empoleirado numa árvore\"
estadoFinal = \"Ficou envergonhado e confuso\"""" .


###  http://www.semanticweb.org/rpcw2026/fabula#Queijo_Valioso
:Queijo_Valioso rdf:type owl:NamedIndividual ,
                         :Queijo ;
                owl:topDataProperty """nome = \"Queijo\"
descricao = \"Objeto apetitoso que o Corvo segurava no bico\"
valor = \"Valioso\"
estadoInicial = \"Na posse do Corvo\"
estadoFinal = \"Na posse da Raposa\"""" .


###  http://www.semanticweb.org/rpcw2026/fabula#Ramo_Alto
:Ramo_Alto rdf:type owl:NamedIndividual ,
                    :Ramo ;
           owl:topDataProperty """nome = \"Ramo alto\"
descricao = \"Ramo da árvore onde o Corvo estava empoleirado\"""" .


###  http://www.semanticweb.org/rpcw2026/fabula#Raposa_Mestre
:Raposa_Mestre rdf:type owl:NamedIndividual ,
                        :Raposa ;
               :deixaCair :Queijo_Valioso ;
               :interageCom :Raposa_Mestre ;
               owl:topDataProperty """nome = \"Mestre Raposa\"
descricao = \"Raposa astuta que enganou o Corvo através de elogios\"""" .


###  http://www.semanticweb.org/rpcw2026/fabula#Vaidade_Corvo
:Vaidade_Corvo rdf:type owl:NamedIndividual ,
                        :Vaidade ;
               :temCaracteristica :Vaidade_Corvo ;
               rdfs:comment "\"Sentimento sentido pelo Corvo ao ouvir os elogios da Raposa\"" .


###  http://www.semanticweb.org/rpcw2026/fabula#Vergonha_Corvo
:Vergonha_Corvo rdf:type owl:NamedIndividual ,
                         :Vergonha ;
                :temSentimento :Vergonha_Corvo ;
                rdfs:comment "\"Sentimento do Corvo depois de perceber que foi enganado\"" .


